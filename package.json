{
  "name": "emberfire",
  "description": "The officially supported Ember binding for Firebase",
  "version": "2.0.17",
  "author": "Firebase (https://firebase.google.com/)",
  "homepage": "https://github.com/firebase/emberfire/",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "start": "ember server",
    "build": "ember build",
    "test": "ember try:testall",
    "legacy": "gulp legacy"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/firebase/emberfire.git"
  },
  "bugs": {
    "url": "https://github.com/firebase/emberfire/issues"
  },
  "license": "MIT",
  "keywords": [
    "ember",
    "firebase",
    "realtime",
    "ember-addon"
  ],
  "ember-addon": {
    "configPath": "tests/dummy/config",
    "fastbootDependencies": [
      "firebase"
    ]
  },
  "browserify": {
    "transform": [
      "babelify",
      "browserify-shim"
    ]
  },
  "browserify-shim": {
    "ember": "global:Ember",
    "ember-data": "global:DS",
    "firebase": "global:firebase"
  },
  "dependencies": {
    "broccoli-merge-trees": "^1.2.1",
    "broccoli-webpack": "^1.0.0",
    "chalk": "1.1.3",
    "ember-cli-babel": "^7.26.10",
    "firebase": "^3.4.1"
  },
  "devDependencies": {
    "@ember/optional-features": "^2.0.0",
    "babelify": "6.4.0",
    "blueimp-md5": "2.19.0",
    "broccoli-asset-rev": "^3.0.0",
    "browserify": "10.2.6",
    "browserify-shim": "3.8.12",
    "codeclimate-test-reporter": "^0.3.3",
    "del": "1.2.0",
    "ember-ajax": "5.1.1",
    "ember-cli": "~3.28.0",
    "ember-cli-app-version": "^5.0.0",
    "ember-cli-code-coverage": "^1.0.3",
    "ember-cli-dependency-checker": "^3.2.0",
    "ember-cli-htmlbars": "^5.7.2",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-jshint": "^1.0.0",
    "ember-cli-qunit": "^4.4.0",
    "ember-cli-release": "0.2.8",
    "ember-cli-shims": "1.2.0",
    "ember-cli-sri": "^2.1.1",
    "ember-cli-terser": "^4.0.2",
    "ember-cli-test-loader": "^3.0.0",
    "ember-data": "~3.28.6",
    "ember-disable-prototype-extensions": "^1.1.3",
    "ember-export-application-global": "^2.0.1",
    "ember-load-initializers": "^2.1.2",
    "ember-resolver": "^8.0.3",
    "ember-sinon": "5.0.0",
    "ember-source": "~3.28.0",
    "ember-try": "^1.4.0",
    "glob": "5.0.13",
    "gulp": "3.9.1",
    "gulp-concat": "2.6.0",
    "gulp-header": "1.8.2",
    "gulp-jshint": "1.11.2",
    "gulp-load-plugins": "0.10.0",
    "gulp-rename": "1.2.2",
    "gulp-sourcemaps": "1.6.0",
    "gulp-uglify": "1.5.3",
    "gulp-util": "3.0.7",
    "loader.js": "^4.7.0",
    "moment": "2.29.1",
    "sinon": "^1.17.3",
    "vinyl-buffer": "1.0.0",
    "vinyl-source-stream": "1.1.0"
  },
  "ember": {
    "edition": "octane"
  }
}
